# ============================================
# Loja Veloz - Environment Variables
# ============================================
# Copy this file to .env and customize values as needed
# cp .env.example .env (Linux/Mac)
# copy .env.example .env (Windows CMD)
# Copy-Item .env.example .env (Windows PowerShell)

# ============================================
# API Security
# ============================================
# API key for authentication between client and API Gateway
# CHANGE THIS in production!
API_KEY=loja-veloz-secret-key-2024

# ============================================
# Service URLs (Docker internal networking)
# ============================================
# These are internal Docker network URLs - don't change for local development
PEDIDOS_SERVICE_URL=http://pedidos:3001
PAGAMENTOS_SERVICE_URL=http://pagamentos:3002
ESTOQUE_SERVICE_URL=http://estoque:3003

# ============================================
# Environment
# ============================================
NODE_ENV=production

# ============================================
# Optional: Observability Stack
# ============================================
# Uncomment if using Prometheus/Grafana stack
# PROMETHEUS_URL=http://prometheus:9090
# JAEGER_AGENT_HOST=jaeger
# JAEGER_AGENT_PORT=6831

# ============================================
# Optional: Database (for future expansion)
# ============================================
# DATABASE_URL=postgresql://user:password@postgres:5432/loja_veloz
# REDIS_URL=redis://redis:6379
